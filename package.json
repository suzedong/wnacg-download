{
  "name": "wnacg-downloader",
  "version": "1.0.0",
  "description": "Interactive CLI for downloading comics from wnacg.com",
  "type": "module",
  "main": "dist/ui/main.js",
  "bin": {
    "wnacg-dl": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && tsc -p tsconfig.preload.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "dev:ui": "vite",
    "build:ui": "vite build",
    "electron:dev": "npm run build && electron .",
    "electron:build": "electron-builder"
  },
  "keywords": [
    "comic",
    "downloader",
    "wnacg",
    "cli",
    "electron",
    "vue"
  ],
  "build": {
    "appId": "com.wnacg.downloader",
    "productName": "WNACG Downloader",
    "directories": {
      "output": "dist/build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": [
        "deb",
        "rpm",
        "AppImage"
      ]
    }
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0-rc.12",
    "commander": "^12.0.0",
    "conf": "^12.0.0",
    "figures": "^6.0.0",
    "inquirer": "^9.2.0",
    "ora": "^8.0.0",
    "playwright": "^1.40.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.10.0",
    "@types/vue": "^1.0.31",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.2",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.8",
    "vitest": "^1.0.0",
    "vue": "^3.5.32"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
