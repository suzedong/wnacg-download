{
  "name": "wnacg-downloader",
  "version": "1.0.0",
  "description": "Interactive CLI for downloading comics from wnacg.com",
  "type": "module",
  "main": "dist/ui/main.js",
  "bin": {
    "wnacg-dl": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "dev:ui": "vite",
    "dev:api": "tsx src/api-server.ts",
    "dev:web": "concurrently \"npm run dev:api\" \"npm run dev:ui\"",
    "build:ui": "vite build",
    "dev:tauri": "tauri dev",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:preview": "tauri dev --no-watch"
  },
  "keywords": [
    "comic",
    "downloader",
    "wnacg",
    "cli",
    "tauri",
    "vue"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0-rc.12",
    "commander": "^12.0.0",
    "conf": "^12.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "figures": "^6.0.0",
    "inquirer": "^9.2.0",
    "ora": "^8.0.0",
    "playwright": "^1.40.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.10.0",
    "@types/vue": "^1.0.31",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^8.2.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.2",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.8",
    "vitest": "^1.0.0",
    "vue": "^3.5.32"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
